{
  "imports": {
    "hono": "jsr:@hono/hono@^4.12.18"
  },
  "tasks": {
    "start": "deno run --allow-net src/main.ts",
    "dev": "deno run --watch --allow-net src/main.ts"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "fmt": {
    "include": ["config/", "src/"],
    "semiColons": false
  },
  "lint": {
    "include": ["config/", "src/"]
  }
}
